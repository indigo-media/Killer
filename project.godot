; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Killer"
run/main_scene="res://Title.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="uid://ppftwtjaor6k"

[autoload]

Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"
TransitionFull="*res://Transition.tscn"
Heartbeat="*res://Heartbeat.tscn"
Gamedata="*res://addons/dialogic/gamedata.gd"
Music="*res://music.tscn"
onLevel="*res://on_level.gd"
Inventory="*res://Inventory.tscn"

[dialogic]

directories/dch_directory={
"Game": "res://addons/dialogic/Game.dch"
}
directories/dtl_directory={
"AxManIntro": "res://AxManIntro.dtl",
"BloodyNote": "res://addons/dialogic/BloodyNote.dtl",
"Bombhasbeenplanted": "res://Bombhasbeenplanted.dtl",
"HidingRoom1Encounter": "res://HidingRoom1Encounter.dtl",
"Intro": "res://Intro.dtl",
"Lvl 1": "res://addons/dialogic/Lvl 1.dtl",
"NoteThe2": "res://NoteThe2.dtl",
"Plinth1": "res://Plinth1.dtl",
"Yougottakey": "res://Yougottakey.dtl",
"candle": "res://candle.dtl",
"dialogic": "res://dialogic.dtl",
"laBook1": "res://laBook1.dtl",
"lightsOut": "res://lightsOut.dtl",
"masterKeygottem": "res://masterKeygottem.dtl",
"notyet": "res://notyet.dtl",
"timeline": "res://timeline.dtl",
"yougottabomb": "res://yougottabomb.dtl"
}
glossary/default_case_sensitive=true
layout/style_list=["res://KillerText.tres"]
layout/default_style="res://KillerText.tres"
variables={}
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}

[display]

window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/gdfxr/plugin.cfg")

